root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# F# — formatted by Fantomas (https://fsprojects.github.io/fantomas)
[*.fs]
indent_size = 4
max_line_length = 120
fsharp_space_before_uppercase_invocation = false
fsharp_multiline_bracket_style = aligned

[*.{fsproj,csproj,props,targets}]
indent_size = 2
