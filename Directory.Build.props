<Project>

  <!-- Shared metadata + compiler settings for every project in the solution. -->
  <PropertyGroup>
    <Product>CrawlSage</Product>
    <Authors>gnrkr789</Authors>
    <Company>CrawlSage</Company>
    <Copyright>Copyright (c) 2026 gnrkr789</Copyright>
    <Version>0.1.1</Version>

    <!-- An F#-first web crawling and scraping framework for .NET. -->
    <Description>An F#-first web crawling and scraping framework for .NET.</Description>
    <!-- Project website = the docs site (Pages); source repository = GitHub. -->
    <PackageProjectUrl>https://gnrkr789.github.io/CrawlSage/</PackageProjectUrl>
    <RepositoryUrl>https://github.com/gnrkr789/CrawlSage</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>fsharp;crawler;scraper;scraping;spider;web</PackageTags>
  </PropertyGroup>

  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <!-- Null-safety in CrawlSage is expressed with F# `option` + `Option.ofObj`, so the
         C#-style nullable-reference feature is left off to avoid BCL-interop warning noise. -->
    <WarningLevel>5</WarningLevel>
    <!-- Keep CI green on warnings for now; tighten once the API stabilises. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

</Project>
